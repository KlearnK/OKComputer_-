import { useState } from 'react';
import { Card, CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar';
import { Badge } from '@/components/ui/badge';
import type { TeamMember, MemberProgress, TeamMemberAnnualGoal } from '@/types/team';
import { 
  Users, 
  User, 
  Building, 
  Mail, 
  Phone, 
  Calendar,
  Edit2, 
  Trash2, 
  ChevronRight,
  TrendingUp,
  Target,
  ChevronDown,
  ChevronUp,
  Edit3,
  Plus
} from 'lucide-react';

interface TeamMemberListProps {
  members: TeamMember[];
  memberProgress: Record<string, MemberProgress>;
  annualGoals: TeamMemberAnnualGoal[];
  onEdit: (member: TeamMember) => void;
  onDelete: (id: string) => void;
  onSelectMember: (member: TeamMember) => void;
  onEditGoal: (goal: TeamMemberAnnualGoal) => void;
  onCreateGoal: (memberId: string) => void;
}

export const TeamMemberList = ({
  members,
  memberProgress,
  annualGoals,
  onEdit,
  onDelete,
  onSelectMember,
  onEditGoal,
  onCreateGoal,
}: TeamMemberListProps) => {
  const [expandedId, setExpandedId] = useState<string | null>(null);

  if (members.length === 0) {
    return (
      <Card className="w-full">
        <CardContent className="py-12 text-center">
          <div className="w-16 h-16 mx-auto mb-4 rounded-full bg-slate-100 flex items-center justify-center">
            <Users className="w-8 h-8 text-slate-400" />
          </div>
          <p className="text-slate-500 text-sm">暂无团队成员</p>
          <p className="text-slate-400 text-xs mt-1">请先添加团队成员</p>
        </CardContent>
      </Card>
    );
  }

  const getInitials = (name: string) => {
    return name.charAt(0).toUpperCase();
  };

  const getProgressColor = (progress: number) => {
    if (progress >= 80) return 'bg-green-500';
    if (progress >= 60) return 'bg-blue-500';
    if (progress >= 40) return 'bg-amber-500';
    return 'bg-red-500';
  };

  return (
    <div className="space-y-4">
      {members.map((member) => {
        const progress = memberProgress[member.id];
        const isExpanded = expandedId === member.id;
        const memberAnnualGoals = annualGoals.filter(g => g.memberId === member.id);

        return (
          <Card
            key={member.id}
            className={`w-full overflow-hidden hover:shadow-lg transition-all duration-300 group ${
              member.status === 'inactive' ? 'opacity-60' : ''
            }`}
          >
            <CardContent className="p-0">
              <div
                className="p-5 cursor-pointer hover:bg-slate-50 transition-colors"
                onClick={() => setExpandedId(isExpanded ? null : member.id)}
              >
                <div className="flex items-start justify-between">
                  <div className="flex items-center gap-4">
                    <Avatar className="w-14 h-14">
                      <AvatarImage src={member.avatar} />
                      <AvatarFallback className="bg-gradient-to-br from-indigo-100 to-purple-100 text-indigo-600 font-semibold">
                        {getInitials(member.name)}
                      </AvatarFallback>
                    </Avatar>

                    <div className="flex-1">
                      <div className="flex items-center gap-3 mb-2">
                        <h3 className="font-semibold text-slate-800 text-lg">{member.name}</h3>
                        <Badge 
                          variant={member.status === 'active' ? 'default' : 'secondary'}
                          className={member.status === 'active' 
                            ? 'bg-green-100 text-green-700 hover:bg-green-100' 
                            : 'bg-slate-100 text-slate-600 hover:bg-slate-100'
                          }
                        >
                          {member.status === 'active' ? '在职' : '离职'}
                        </Badge>
                      </div>

                      <div className="flex flex-wrap gap-4 text-sm text-slate-500">
                        <span className="flex items-center gap-1">
                          <Building className="w-3.5 h-3.5" />
                          {member.department || '未设置'}
                        </span>
                        <span className="flex items-center gap-1">
                          <User className="w-3.5 h-3.5" />
                          {member.role || '未设置'}
                        </span>
                        <span className="flex items-center gap-1">
                          <Mail className="w-3.5 h-3.5" />
                          {member.email}
                        </span>
                        {member.phone && (
                          <span className="flex items-center gap-1">
                            <Phone className="w-3.5 h-3.5" />
                            {member.phone}
                          </span>
                        )}
                      </div>
                    </div>
                  </div>

                  <div className="flex items-center gap-2 ml-4">
                    {progress && (
                      <div className="hidden md:flex items-center gap-2">
                        <div className="flex items-center gap-1.5">
                          <Target className="w-4 h-4 text-indigo-500" />
                          <span className="text-sm font-medium text-indigo-600">
                            {progress.monthlyBreakdownProgress.toFixed(0)}%
                          </span>
                        </div>
                      </div>
                    )}

                    <div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={(e) => {
                          e.stopPropagation();
                          onEdit(member);
                        }}
                        className="h-8 w-8 p-0 text-slate-500 hover:text-indigo-600"
                      >
                        <Edit2 className="w-4 h-4" />
                      </Button>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={(e) => {
                          e.stopPropagation();
                          onDelete(member.id);
                        }}
                        className="h-8 w-8 p-0 text-slate-500 hover:text-red-600"
                      >
                        <Trash2 className="w-4 h-4" />
                      </Button>
                    </div>

                    <Button
                      variant="outline"
                      size="sm"
                      onClick={(e) => {
                        e.stopPropagation();
                        onSelectMember(member);
                      }}
                      className="text-xs border-indigo-200 text-indigo-600 hover:bg-indigo-50"
                    >
                      查看详情
                      <ChevronRight className="w-3.5 h-3.5 ml-1" />
                    </Button>
                  </div>
                </div>

                {progress && (
                  <div className="mt-4 space-y-3">
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-slate-600">月度目标进度</span>
                      <span className="text-sm font-medium text-indigo-600">
                        {progress.monthlyBreakdownProgress.toFixed(1)}%
                      </span>
                    </div>
                    <div className="w-full bg-slate-100 rounded-full h-2">
                      <div 
                        className={`h-2 rounded-full transition-all duration-500 ${getProgressColor(progress.monthlyBreakdownProgress)}`}
                        style={{ width: `${Math.min(progress.monthlyBreakdownProgress, 100)}%` }}
                      />
                    </div>

                    <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                      <div className="bg-slate-50 rounded-lg p-3">
                        <p className="text-xs text-slate-500 mb-1">年度目标</p>
                        <p className="text-lg font-bold text-slate-700">
                          {progress.totalAnnualGoals}
                        </p>
                      </div>
                      <div className="bg-slate-50 rounded-lg p-3">
                        <p className="text-xs text-slate-500 mb-1">月度目标</p>
                        <p className="text-lg font-bold text-slate-700">
                          {progress.totalMonthlyGoals}
                        </p>
                      </div>
                      <div className="bg-slate-50 rounded-lg p-3">
                        <p className="text-xs text-slate-500 mb-1">周目标</p>
                        <p className="text-lg font-bold text-slate-700">
                          {progress.totalWeeklyGoals}
                        </p>
                      </div>
                      <div className="bg-slate-50 rounded-lg p-3">
                        <p className="text-xs text-slate-500 mb-1">完成率</p>
                        <p className="text-lg font-bold text-green-600">
                          {progress.monthlyBreakdownProgress.toFixed(0)}%
                        </p>
                      </div>
                    </div>
                  </div>
                )}

                <div className="flex items-center justify-between mt-4 pt-4 border-t border-slate-100">
                  <div className="text-xs text-slate-500 flex items-center gap-1">
                    <Calendar className="w-3.5 h-3.5" />
                    入职: {new Date(member.joinDate).toLocaleDateString('zh-CN')}
                  </div>

                  {isExpanded ? (
                    <ChevronUp className="w-4 h-4 text-slate-400" />
                  ) : (
                    <ChevronDown className="w-4 h-4 text-slate-400" />
                  )}
                </div>
              </div>

              {isExpanded && (
                <div className="px-5 pb-5 pt-2 bg-slate-50/50 border-t border-slate-100">
                  {/* 年度目标列表 */}
                  {memberAnnualGoals.length > 0 && (
                    <div className="mb-4">
                      <h4 className="text-sm font-medium text-slate-700 mb-3 flex items-center gap-2">
                        <Target className="w-4 h-4 text-indigo-500" />
                        年度目标 ({memberAnnualGoals.length}个)
                      </h4>
                      <div className="space-y-2">
                        {memberAnnualGoals.map(goal => (
                          <div key={goal.id} className="bg-white rounded-lg p-3 shadow-sm flex items-center justify-between">
                            <div>
                              <p className="font-medium text-slate-800">{goal.year}年目标</p>
                              <p className="text-xs text-slate-500">
                                收入: ¥{goal.breakdownGoals.income.toLocaleString()} | 
                                单量: {goal.breakdownGoals.orderCount} | 
                                新增名单: {goal.executionGoals.newLeads}
                              </p>
                            </div>
                            <div className="flex gap-2">
                              <Button
                                variant="ghost"
                                size="sm"
                                onClick={(e) => {
                                  e.stopPropagation();
                                  onEditGoal(goal);
                                }}
                                className="h-7 px-2 text-xs text-indigo-600 hover:text-indigo-700"
                              >
                                <Edit3 className="w-3 h-3 mr-1" />
                                编辑
                              </Button>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* 创建新目标按钮 */}
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={(e) => {
                      e.stopPropagation();
                      onCreateGoal(member.id);
                    }}
                    className="w-full flex items-center justify-center gap-2 border-dashed"
                  >
                    <Plus className="w-4 h-4" />
                    为该成员创建年度目标
                  </Button>

                  <div className="grid grid-cols-2 md:grid-cols-4 gap-3 mt-4">
                    <div className="bg-white rounded-lg p-3 shadow-sm">
                      <p className="text-xs text-slate-500 mb-1">姓名</p>
                      <p className="font-semibold text-slate-800">{member.name}</p>
                    </div>
                    <div className="bg-white rounded-lg p-3 shadow-sm">
                      <p className="text-xs text-slate-500 mb-1">部门</p>
                      <p className="font-semibold text-slate-800">{member.department || '-'}</p>
                    </div>
                    <div className="bg-white rounded-lg p-3 shadow-sm">
                      <p className="text-xs text-slate-500 mb-1">职位</p>
                      <p className="font-semibold text-slate-800">{member.role || '-'}</p>
                    </div>
                    <div className="bg-white rounded-lg p-3 shadow-sm">
                      <p className="text-xs text-slate-500 mb-1">状态</p>
                      <p className="font-semibold">
                        <Badge 
                          variant={member.status === 'active' ? 'default' : 'secondary'}
                          className={member.status === 'active' 
                            ? 'bg-green-100 text-green-700' 
                            : 'bg-slate-100 text-slate-600'
                          }
                        >
                          {member.status === 'active' ? '在职' : '离职'}
                        </Badge>
                      </p>
                    </div>
                  </div>

                  {progress && (
                    <div className="bg-white rounded-lg p-4 shadow-sm mt-4">
                      <h4 className="text-sm font-medium text-slate-700 mb-3 flex items-center gap-2">
                        <TrendingUp className="w-4 h-4 text-indigo-500" />
                        目标统计
                      </h4>
                      <div className="grid grid-cols-2 md:grid-cols-5 gap-3">
                        <div className="text-center">
                          <p className="text-lg font-bold text-indigo-600">{progress.totalAnnualGoals}</p>
                          <p className="text-xs text-slate-500">年度目标</p>
                        </div>
                        <div className="text-center">
                          <p className="text-lg font-bold text-blue-600">{progress.totalMonthlyGoals}</p>
                          <p className="text-xs text-slate-500">月度目标</p>
                        </div>
                        <div className="text-center">
                          <p className="text-lg font-bold text-purple-600">{progress.totalWeeklyGoals}</p>
                          <p className="text-xs text-slate-500">周目标</p>
                        </div>
                        <div className="text-center">
                          <p className="text-lg font-bold text-green-600">{progress.monthlyBreakdownProgress.toFixed(0)}%</p>
                          <p className="text-xs text-slate-500">拆解进度</p>
                        </div>
                        <div className="text-center">
                          <p className="text-lg font-bold text-amber-600">{progress.monthlyExecutionProgress.toFixed(0)}%</p>
                          <p className="text-xs text-slate-500">执行进度</p>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              )}
            </CardContent>
          </Card>
        );
      })}
    </div>
  );
};
