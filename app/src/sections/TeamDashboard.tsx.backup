import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';
import { Progress } from '@/components/ui/progress';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar';
import type { TeamStats } from '@/types/team';
import type { MemberProgress } from '@/types/team';
import type { TeamMember } from '@/types/team';
import { 
  Users, 
  Target, 
  Calendar, 
  CalendarDays,
  Award,
  BarChart3,
  Crown,
  Activity
} from 'lucide-react';

interface TeamDashboardProps {
  stats: TeamStats;
  members: TeamMember[];
  memberProgress: Record<string, MemberProgress>;
}

export const TeamDashboard = ({ stats, members, memberProgress }: TeamDashboardProps) => {
  const getInitials = (name: string) => {
    return name.charAt(0).toUpperCase();
  };

  return (
    <div className="space-y-6">
      {/* 团队统计概览 */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        <Card className="hover:shadow-lg transition-shadow duration-300">
          <CardContent className="p-5">
            <div className="flex items-center justify-between mb-4">
              <div className="w-12 h-12 rounded-xl bg-indigo-100 flex items-center justify-center">
                <Users className="w-6 h-6 text-indigo-600" />
              </div>
              <div className="text-right">
                <p className="text-2xl font-bold text-slate-800">{stats.totalMembers}</p>
                <p className="text-xs text-slate-500">团队成员</p>
              </div>
            </div>
            <div className="flex items-center gap-2">
              <span className="text-xs text-slate-500">在职:</span>
              <span className="text-sm font-medium text-green-600">{stats.activeMembers}</span>
            </div>
          </CardContent>
        </Card>

        <Card className="hover:shadow-lg transition-shadow duration-300">
          <CardContent className="p-5">
            <div className="flex items-center justify-between mb-4">
              <div className="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center">
                <Target className="w-6 h-6 text-green-600" />
              </div>
              <div className="text-right">
                <p className="text-2xl font-bold text-slate-800">{stats.totalAnnualGoals}</p>
                <p className="text-xs text-slate-500">年度目标</p>
              </div>
            </div>
            <div className="flex items-center gap-2">
              <span className="text-xs text-slate-500">人均:</span>
              <span className="text-sm font-medium text-slate-700">
                {(stats.totalAnnualGoals / Math.max(stats.activeMembers, 1)).toFixed(1)}
              </span>
            </div>
          </CardContent>
        </Card>

        <Card className="hover:shadow-lg transition-shadow duration-300">
          <CardContent className="p-5">
            <div className="flex items-center justify-between mb-4">
              <div className="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center">
                <Calendar className="w-6 h-6 text-blue-600" />
              </div>
              <div className="text-right">
                <p className="text-2xl font-bold text-slate-800">{stats.totalMonthlyGoals}</p>
                <p className="text-xs text-slate-500">月度目标</p>
              </div>
            </div>
            <div className="flex items-center gap-2">
              <span className="text-xs text-slate-500">平均进度:</span>
              <span className="text-sm font-medium text-blue-600">
                {stats.avgBreakdownProgress.toFixed(1)}%
              </span>
            </div>
          </CardContent>
        </Card>

        <Card className="hover:shadow-lg transition-shadow duration-300">
          <CardContent className="p-5">
            <div className="flex items-center justify-between mb-4">
              <div className="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center">
                <CalendarDays className="w-6 h-6 text-purple-600" />
              </div>
              <div className="text-right">
                <p className="text-2xl font-bold text-slate-800">{stats.totalWeeklyGoals}</p>
                <p className="text-xs text-slate-500">周目标</p>
              </div>
            </div>
            <div className="flex items-center gap-2">
              <span className="text-xs text-slate-500">执行进度:</span>
              <span className="text-sm font-medium text-purple-600">
                {stats.avgExecutionProgress.toFixed(1)}%
              </span>
            </div>
          </CardContent>
        </Card>
      </div>

      {/* 团队平均进度 */}
      <Card className="hover:shadow-lg transition-shadow duration-300">
        <CardHeader>
          <CardTitle className="flex items-center gap-2 text-lg font-semibold text-slate-800">
            <Activity className="w-5 h-5 text-indigo-600" />
            团队平均进度
          </CardTitle>
        </CardHeader>
        <CardContent className="space-y-6">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <div className="flex justify-between items-center mb-3">
                <span className="text-sm font-medium text-slate-700">拆解类目标平均进度</span>
                <span className="text-lg font-bold text-indigo-600">
                  {stats.avgBreakdownProgress.toFixed(1)}%
                </span>
              </div>
              <Progress value={stats.avgBreakdownProgress} className="h-3 bg-indigo-100" />
            </div>
            <div>
              <div className="flex justify-between items-center mb-3">
                <span className="text-sm font-medium text-slate-700">执行类目标平均进度</span>
                <span className="text-lg font-bold text-green-600">
                  {stats.avgExecutionProgress.toFixed(1)}%
                </span>
              </div>
              <Progress value={stats.avgExecutionProgress} className="h-3 bg-green-100" />
            </div>
          </div>
        </CardContent>
      </Card>

      {/* 排行榜 */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* 拆解类目标排行榜 */}
        <Card className="hover:shadow-lg transition-shadow duration-300">
          <CardHeader>
            <CardTitle className="flex items-center gap-2 text-lg font-semibold text-slate-800">
              <Crown className="w-5 h-5 text-amber-500" />
              拆解类目标排行榜
            </CardTitle>
          </CardHeader>
          <CardContent>
            {stats.topPerformers.length === 0 ? (
              <p className="text-center text-slate-500 py-8">暂无数据</p>
            ) : (
              <div className="space-y-3">
                {stats.topPerformers.map((performer, index) => {
                  const member = members.find(m => m.id === performer.memberId);
                  return (
                    <div key={performer.memberId} className="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                      <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm ${
                        index === 0 ? 'bg-amber-400 text-white' :
                        index === 1 ? 'bg-slate-300 text-slate-700' :
                        index === 2 ? 'bg-orange-400 text-white' :
                        'bg-slate-200 text-slate-600'
                      }`}>
                        {index + 1}
                      </div>
                      <Avatar className="w-10 h-10">
                        <AvatarImage src={member?.avatar} />
                        <AvatarFallback className="bg-indigo-100 text-indigo-600">
                          {member ? getInitials(member.name) : '?'}
                        </AvatarFallback>
                      </Avatar>
                      <div className="flex-1">
                        <p className="font-medium text-slate-800">{performer.memberName}</p>
                        <div className="flex items-center gap-2 mt-1">
                          <div className="w-24 bg-slate-200 rounded-full h-1.5">
                            <div 
                              className="bg-indigo-500 h-1.5 rounded-full"
                              style={{ width: `${performer.breakdownProgress}%` }}
                            />
                          </div>
                          <span className="text-xs font-medium text-indigo-600">
                            {performer.breakdownProgress.toFixed(1)}%
                          </span>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </CardContent>
        </Card>

        {/* 执行类目标排行榜 */}
        <Card className="hover:shadow-lg transition-shadow duration-300">
          <CardHeader>
            <CardTitle className="flex items-center gap-2 text-lg font-semibold text-slate-800">
              <Award className="w-5 h-5 text-green-500" />
              执行类目标排行榜
            </CardTitle>
          </CardHeader>
          <CardContent>
            {stats.topPerformers.length === 0 ? (
              <p className="text-center text-slate-500 py-8">暂无数据</p>
            ) : (
              <div className="space-y-3">
                {stats.topPerformers.map((performer, index) => {
                  const member = members.find(m => m.id === performer.memberId);
                  return (
                    <div key={performer.memberId} className="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                      <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm ${
                        index === 0 ? 'bg-amber-400 text-white' :
                        index === 1 ? 'bg-slate-300 text-slate-700' :
                        index === 2 ? 'bg-orange-400 text-white' :
                        'bg-slate-200 text-slate-600'
                      }`}>
                        {index + 1}
                      </div>
                      <Avatar className="w-10 h-10">
                        <AvatarImage src={member?.avatar} />
                        <AvatarFallback className="bg-green-100 text-green-600">
                          {member ? getInitials(member.name) : '?'}
                        </AvatarFallback>
                      </Avatar>
                      <div className="flex-1">
                        <p className="font-medium text-slate-800">{performer.memberName}</p>
                        <div className="flex items-center gap-2 mt-1">
                          <div className="w-24 bg-slate-200 rounded-full h-1.5">
                            <div 
                              className="bg-green-500 h-1.5 rounded-full"
                              style={{ width: `${performer.executionProgress}%` }}
                            />
                          </div>
                          <span className="text-xs font-medium text-green-600">
                            {performer.executionProgress.toFixed(1)}%
                          </span>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </CardContent>
        </Card>
      </div>

      {/* 成员目标统计 */}
      <Card className="hover:shadow-lg transition-shadow duration-300">
        <CardHeader>
          <CardTitle className="flex items-center gap-2 text-lg font-semibold text-slate-800">
            <BarChart3 className="w-5 h-5 text-indigo-600" />
            成员目标统计
          </CardTitle>
        </CardHeader>
        <CardContent>
          {members.length === 0 ? (
            <p className="text-center text-slate-500 py-8">暂无团队成员</p>
          ) : (
            <div className="space-y-4">
              {members.filter(m => m.status === 'active').map(member => {
                const progress = memberProgress[member.id];
                if (!progress) return null;

                return (
                  <div key={member.id} className="flex items-center gap-4 p-4 bg-slate-50 rounded-lg">
                    <Avatar className="w-12 h-12">
                      <AvatarImage src={member.avatar} />
                      <AvatarFallback className="bg-indigo-100 text-indigo-600">
                        {getInitials(member.name)}
                      </AvatarFallback>
                    </Avatar>
                    <div className="flex-1">
                      <p className="font-medium text-slate-800">{member.name}</p>
                      <p className="text-sm text-slate-500">{member.department || '未设置部门'}</p>
                    </div>
                    <div className="flex items-center gap-6">
                      <div className="text-center">
                        <p className="text-sm font-medium text-slate-700">年度目标</p>
                        <p className="text-lg font-bold text-indigo-600">{progress.totalAnnualGoals}</p>
                      </div>
                      <div className="text-center">
                        <p className="text-sm font-medium text-slate-700">月度目标</p>
                        <p className="text-lg font-bold text-blue-600">{progress.totalMonthlyGoals}</p>
                      </div>
                      <div className="text-center">
                        <p className="text-sm font-medium text-slate-700">周目标</p>
                        <p className="text-lg font-bold text-purple-600">{progress.totalWeeklyGoals}</p>
                      </div>
                      <div className="text-center">
                        <p className="text-sm font-medium text-slate-700">完成率</p>
                        <p className="text-lg font-bold text-green-600">
                          {Math.round(
                            ((progress.completedAnnualGoals + progress.completedMonthlyGoals + progress.completedWeeklyGoals) /
                            (progress.totalAnnualGoals + progress.totalMonthlyGoals + progress.totalWeeklyGoals)) *
                            100 || 0
                          )}%
                        </p>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </CardContent>
      </Card>
    </div>
  );
};
